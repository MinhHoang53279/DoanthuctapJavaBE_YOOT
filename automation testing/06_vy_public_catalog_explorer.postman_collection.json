{
  "info": {
    "_postman_id": "9a9d0006-6f81-4a2b-9c41-000600060006",
    "name": "06 - Vy public catalog explorer",
    "description": "Persona Vy: anonymous visitor explores public catalog, health endpoints, pagination, and protected boundaries without logging in. Count: 25 pm.test test cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "password",
      "value": "Password@123"
    },
    {
      "key": "adminEmail",
      "value": "admin@example.com"
    },
    {
      "key": "adminPassword",
      "value": "Password@123"
    },
    {
      "key": "managerEmail",
      "value": "admin@example.com"
    },
