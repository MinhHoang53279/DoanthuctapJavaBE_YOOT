              "pm.test(\"tags endpoint returns an array\", function () { pm.expect(json.data).to.be.an(\"array\"); });"
            ]
          }
        }
      ]
    },
    {
      "name": "06.07 - Vy browses public deck catalog first page",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/decks?page=0&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "decks?page=0&size=5"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const page = pm.response.json().data;",
              "pm.test(\"public deck catalog returns HTTP 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"public deck catalog has page metadata\", function () { pm.expect(page).to.include.keys([\"items\", \"page\", \"size\", \"totalItems\", \"totalPages\"]); });",
              "pm.test(\"public deck catalog respects requested size\", function () { pm.expect(page.size).to.eql(5); });"
            ]
          }
        }
      ]
    },
    {
      "name": "06.08 - Vy searches deck catalog with no match",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/decks?keyword=unlikely-public-keyword-{{runId}}&page=0&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "decks?keyword=unlikely-public-keyword-{{runId}}&page=0&size=5"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const page = pm.response.json().data;",
              "pm.test(\"empty deck search returns HTTP 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"empty deck search returns zero items\", function () { pm.expect(page.items.length).to.eql(0); });"
            ]
          }
        }
      ]
    },
    {
      "name": "06.09 - Vy cannot create anonymous deck",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/decks",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "decks"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Anonymous Deck Should Fail\",\n  \"visibility\": \"PRIVATE\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"anonymous deck create returns HTTP 401\", function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
