              "pm.test(\"manager public deck starts as DRAFT\", function () {",
              "  pm.collectionVariables.set(\"managerApprovedDeckId\", json.data.id);",
              "  pm.expect(json.data.status).to.eql(\"DRAFT\");",
              "});"
            ]
          }
        }
      ]
