        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{baoAdminToken}}",
              "type": "string"
            }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"x{{runId}}\",\n  \"name\": \"Bao Language Duplicate {{runId}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"duplicate language returns HTTP 409\", function () { pm.response.to.have.status(409); });"
            ]
          }
        }
      ]
    },
