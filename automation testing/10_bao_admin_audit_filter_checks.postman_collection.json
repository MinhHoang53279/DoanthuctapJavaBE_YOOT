    {
      "name": "10.06 - Register learner for admin filters",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{baoLearnerEmail}}\",\n  \"username\": \"{{baoLearnerUsername}}\",\n  \"password\": \"{{password}}\",\n  \"fullName\": \"Bao Target {{runId}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"filter learner register returns HTTP 201\", function () {",
              "  const json = pm.response.json();",
              "  pm.response.to.have.status(201);",
              "  pm.collectionVariables.set(\"baoLearnerId\", json.data.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "10.07 - Admin user keyword filter finds learner",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users?keyword={{baoLearnerUsername}}&page=0&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users?keyword={{baoLearnerUsername}}&page=0&size=5"
          ]
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{baoAdminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"keyword filter includes learner\", function () {",
              "  const items = pm.response.json().data.items;",
              "  pm.response.to.have.status(200);",
              "  pm.expect(items.some(x => String(x.id) === pm.collectionVariables.get(\"baoLearnerId\"))).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
