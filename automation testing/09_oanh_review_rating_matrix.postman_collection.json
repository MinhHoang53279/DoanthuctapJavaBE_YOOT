    {
      "name": "09.00 - Prepare Oanh learning run",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/learning/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "learning",
            "health"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now().toString();",
              "pm.collectionVariables.set(\"runId\", runId);",
              "pm.collectionVariables.set(\"oanhEmail\", \"oanh.\" + runId + \"@example.com\");",
              "pm.collectionVariables.set(\"oanhUsername\", \"oanh_\" + runId);",
              "pm.collectionVariables.set(\"oanhFullName\", \"Oanh \" + runId);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test(\"09.00 - Prepare Oanh learning run returns HTTP 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"09.00 - Prepare Oanh learning run confirms learning\", function () { pm.expect(json.data.module).to.eql(\"learning\"); });"
            ]
          }
        }
      ]
    },
