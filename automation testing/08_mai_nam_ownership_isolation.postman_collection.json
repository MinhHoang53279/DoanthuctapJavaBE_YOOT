    {
      "name": "08.00 - Prepare Mai and Nam run",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "health"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now().toString();",
              "pm.collectionVariables.set(\"runId\", runId);",
              "pm.collectionVariables.set(\"maiEmail\", \"mai.\" + runId + \"@example.com\");",
              "pm.collectionVariables.set(\"maiUsername\", \"mai_\" + runId);",
              "pm.collectionVariables.set(\"maiFullName\", \"Mai \" + runId);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test(\"08.00 - Prepare Mai and Nam run returns HTTP 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"08.00 - Prepare Mai and Nam run confirms public auth health\", function () { pm.expect(json.data.module).to.eql(\"auth\"); });"
            ]
          }
        }
      ]
    },
